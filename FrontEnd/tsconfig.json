{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    /* ✅ Alias support */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* ✅ Remove TS deprecation warning */
    "ignoreDeprecations": "6.0",

    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}